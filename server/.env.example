# 阿里云百炼 / DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 国内一般使用：https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际文档常见：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可改为 qwen-plus / qwen-turbo / qwen3.6-plus 等你实际可用模型
QWEN_MODEL=qwen-plus

# 机器人名字
ROBOT_NAME=小智
